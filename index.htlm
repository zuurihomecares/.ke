<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Zuuri Homecares | Professional Services</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;700;800&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    :root {
      --primary-green: #0f4d3a;
      --primary-orange: #ff7a00;
      --light-gray: #f4f5f7;
      --dark-text: #2d3436;
      --white: #ffffff;
      --transition: all 0.3s ease;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Poppins', sans-serif;
      color: var(--dark-text);
      background-color: var(--white);
      scroll-behavior: smooth;
      overflow-x: hidden;
    }

    h1, h2, h3, h4 { font-family: 'Montserrat', sans-serif; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    .section { padding: 80px 0; }
    .section-title { text-align: center; color: var(--primary-green); font-size: 2.5rem; margin-bottom: 50px; font-weight: 800;}
    .bg-light { background-color: var(--light-gray); }

    /* Buttons */
    .btn-primary {
      display: inline-block;
      padding: 15px 28px;
      border-radius: 5px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: var(--transition);
      text-decoration: none;
      font-family: 'Montserrat', sans-serif;
      text-align: center;
      background: var(--primary-orange); 
      color: var(--white);
      width: 100%;
      font-size: 1.1rem;
    }
    .btn-primary:hover { background: #e66a00; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(255,122,0,0.4); }

    /* Header - Transparent & No Buttons */
    header {
      position: absolute; 
      top: 0; left: 0; width: 100%;
      background: transparent;
      display: flex; align-items: center; justify-content: flex-start;
      padding: 20px 50px;
      z-index: 1000;
    }
    .header-logo-img { height: 50px; width: 50px; object-fit: contain; margin-right: 15px; border-radius: 5px;}
    .logo-text { font-size: 1.8rem; font-weight: 800; color: var(--white); text-shadow: 0 2px 10px rgba(0,0,0,0.5); font-family: 'Montserrat', sans-serif;}

    /* Hero */
    .hero {
      height: 100vh;
      position: relative;
      display: flex; align-items: center; justify-content: center;
      text-align: center; color: var(--white);
      background: url('https://images.unsplash.com/photo-1581578731548-c64695cc6952?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80') center/cover no-repeat;
    }
    .hero-overlay { position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(135deg, rgba(15, 77, 58, 0.9) 0%, rgba(15, 77, 58, 0.7) 100%); z-index: 1; }
    .hero-content { position: relative; z-index: 2; max-width: 900px; padding: 0 20px; }
    .hero h1 { font-size: 3.5rem; line-height: 1.2; margin-bottom: 20px; text-shadow: 0 2px 10px rgba(0,0,0,0.3); }
    .hero p { font-size: 1.2rem; margin-bottom: 30px; font-weight: 300; }

    /* Carousel - Landscape Configuration */
    .carousel-wrapper { overflow: hidden; position: relative; padding: 20px 0; }
    .carousel-track { display: flex; gap: 40px; transition: transform 0.5s ease; cursor: grab; }
    .carousel-track:active { cursor: grabbing; }
    
    .service-card {
      min-width: 900px; /* Wide landscape format */
      max-width: 900px;
      height: 480px;
      background: var(--white);
      border-radius: 15px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
      transition: var(--transition);
      display: flex;
      flex-direction: row; /* Image left, content right */
      overflow: hidden;
      border: 1px solid #eaeaea;
    }
    .service-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.2); }
    
    .card-img {
      width: 45%;
      height: 100%;
      background-size: cover;
      background-position: center;
      background-color: var(--light-gray);
      border-right: 4px solid var(--primary-orange);
    }
    
    .card-content-wrapper {
      width: 55%;
      display: flex;
      flex-direction: column;
    }

    .card-content {
      padding: 30px;
      flex-grow: 1;
      overflow-y: auto; 
      text-align: left;
    }
    
    /* Scrollbar styling for cards */
    .card-content::-webkit-scrollbar { width: 6px; }
    .card-content::-webkit-scrollbar-thumb { background-color: #ccc; border-radius: 10px; }
    
    .card-content h3 { color: var(--primary-green); font-size: 1.6rem; margin-bottom: 5px; }
    .card-content .desc { font-size: 1rem; color: #555; margin-bottom: 20px; font-style: italic; }
    
    .card-section-title { font-size: 1.05rem; color: var(--primary-orange); font-weight: 700; margin-top: 15px; margin-bottom: 8px; display: flex; align-items: center; gap: 8px;}
    .card-list { padding-left: 20px; font-size: 0.95rem; color: #444; line-height: 1.6; margin-bottom: 15px; }
    
    .card-footer {
      padding: 20px;
      background: var(--light-gray);
      border-top: 1px solid #ddd;
    }

    /* Contact & Reviews */
    .reviews-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
    .review-card { background: var(--white); padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
    .stars { color: #f1c40f; margin-bottom: 15px; }
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
    .contact-info { background: var(--white); padding: 40px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
    .social-icons { display: flex; gap: 15px; margin: 25px 0; }
    .social-icons a { width: 40px; height: 40px; background: var(--light-gray); display: flex; align-items: center; justify-content: center; border-radius: 50%; color: var(--primary-green); transition: var(--transition); text-decoration: none;}

    /* Footer */
    footer { background: var(--primary-green); color: var(--white); padding: 60px 0 20px; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 40px; }
    .footer-bottom { text-align: center; margin-top: 50px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); opacity: 0.6; font-size: 0.9rem; }

    /* Modals */
    .modal-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.6); backdrop-filter: blur(5px);
      display: flex; justify-content: center; align-items: center;
      z-index: 2000; opacity: 0; visibility: hidden; transition: var(--transition);
    }
    .modal-overlay.active { opacity: 1; visibility: visible; }
    .modal-content {
      background: var(--white); width: 90%; max-width: 800px;
      max-height: 90vh; overflow-y: auto; border-radius: 15px;
      position: relative; transform: translateY(50px); transition: var(--transition);
    }
    .modal-overlay.active .modal-content { transform: translateY(0); }
    .close-btn { position: absolute; top: 20px; right: 25px; font-size: 1.5rem; color: var(--dark-text); cursor: pointer; z-index: 10; }
    
    /* Forms */
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: 500; color: var(--primary-green); }
    .form-control { width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Poppins', sans-serif; font-size: 1rem; }
    .form-control:focus { outline: none; border-color: var(--primary-orange); box-shadow: 0 0 0 3px rgba(255,122,0,0.1); }
    
    /* Mobile Responsiveness */
    @media (max-width: 950px) {
      .service-card { 
        flex-direction: column; 
        min-width: 90vw; 
        max-width: 90vw; 
        height: 600px; 
      }
      .card-img { width: 100%; height: 200px; border-right: none; border-bottom: 4px solid var(--primary-orange); }
      .card-content-wrapper { width: 100%; height: 400px; }
      header { padding: 15px 20px; }
      .hero h1 { font-size: 2.2rem; }
      .contact-grid, .footer-grid { grid-template-columns: 1fr; }
      .form-grid { grid-template-columns: 1fr !important; }
    }
  </style>
</head>
<body>

  <header>
    <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c5/House_icon.svg/512px-House_icon.svg.png" alt="Zuuri Homecares Logo" class="header-logo-img">
    <div class="logo-text">Zuuri Homecares</div>
  </header>

  <section id="home" class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>Zuuri Homecares – Professional Home, Office, Institution & Event Services</h1>
      <p>Your trusted partner for clean, organized, safe, and beautiful spaces in Nairobi.</p>
    </div>
  </section>

  <section id="services" class="section bg-light">
    <div class="container">
      <h2 class="section-title">Our Service Categories</h2>
      <div class="carousel-wrapper">
        <div class="carousel-track" id="carouselTrack">
          </div>
      </div>
    </div>
  </section>

  <section id="reviews" class="section">
    <div class="container">
      <h2 class="section-title">What Our Clients Say</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
          <p>"Zuuri Homecares transformed my office space! The cleaning was thorough and professional."</p>
          <h4>- Sarah K.</h4>
        </div>
        <div class="review-card">
          <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
          <p>"Their handyman service was incredibly fast. Fixed my plumbing issues in no time. Highly recommended."</p>
          <h4>- David M.</h4>
        </div>
      </div>
    </div>
  </section>

  <section id="contact" class="section bg-light">
    <div class="container">
      <h2 class="section-title">Contact Us</h2>
      <div class="contact-grid">
        <div class="contact-info">
          <h3>Get in Touch</h3>
          <p><i class="fas fa-phone-alt" style="color: var(--primary-green)"></i> 0707 113 265</p>
          <p><i class="fas fa-envelope" style="color: var(--primary-green)"></i> hello@zuurihomecares.co.ke</p>
          <p><i class="fas fa-map-marker-alt" style="color: var(--primary-green)"></i> Juja City Mall, Nairobi</p>
          <div class="social-icons">
            <a href="#"><i class="fab fa-facebook-f"></i></a>
            <a href="#"><i class="fab fa-instagram"></i></a>
            <a href="#"><i class="fab fa-tiktok"></i></a>
            <a href="#"><i class="fab fa-whatsapp"></i></a>
          </div>
          <p style="font-weight: bold; color: var(--primary-green)">@zuurihomecare</p>
        </div>
        <div class="contact-map">
          <iframe src="https://maps.google.com/maps?q=Juja%20City%20Mall,%20Nairobi&t=&z=13&ie=UTF8&iwloc=&output=embed" width="100%" height="300" style="border:0; border-radius: 10px;" allowfullscreen="" loading="lazy"></iframe>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="container footer-grid">
      <div>
        <h3>Zuuri Homecares</h3>
        <p style="margin-top:15px; opacity:0.8;">Your Trusted Partner for Clean, Organized, Safe, and Beautiful spaces in Nairobi.</p>
      </div>
      <div>
        <h4 style="margin-bottom: 15px;">Contact</h4>
        <p style="margin-bottom: 5px;">📞 0707 113 265</p>
        <p>📍 Juja City Mall, Nairobi</p>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2026 Zuuri Homecares. All rights reserved.</p>
    </div>
  </footer>

  <div class="modal-overlay" id="bookingModal">
    <div class="modal-content">
      <span class="close-btn" onclick="closeBookingModal()"><i class="fas fa-times"></i></span>
      <div style="padding: 40px;">
        <h2 style="color: var(--primary-green); text-align: center; margin-bottom: 10px;">Book a Service</h2>
        <p style="text-align: center; color: #666; margin-bottom: 30px;">Fill out the form below and our team will get back to you to confirm your appointment.</p>
        
        <form id="bookingForm" onsubmit="submitBooking(event)">
          <div class="form-group">
            <label>Full Name</label>
            <input type="text" class="form-control" name="clientName" required>
          </div>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;" class="form-grid">
            <div class="form-group">
              <label>Phone Number</label>
              <input type="tel" class="form-control" name="phone" placeholder="0707 113 265" required>
            </div>
            <div class="form-group">
              <label>Email Address</label>
              <input type="email" class="form-control" name="email" required>
            </div>
          </div>
          
          <div class="form-group">
            <label>Select Specific Service</label>
            <select class="form-control" name="service" id="bookingServiceSelect" required>
              <option value="" disabled selected>Choose a specific service...</option>
              <option value="Residential Cleaning">Residential Cleaning & Sanitization</option>
              <option value="Home Organization">Home Organization & Rearranging</option>
              <option value="Indoor Relocation">Indoor Relocation & Furniture Movement</option>
              <option value="Interior Design">Interior Design & Home Improvement</option>
              <option value="Handyman Services">Installation & Handyman Services</option>
              <option value="Office Cleaning">Office Cleaning & Workplace Support</option>
              <option value="Institutional Cleaning">Institutional Cleaning & Facility Support</option>
              <option value="Child Supervision">Child Supervision & Homework Support</option>
              <option value="Pet Care">Pet Care & Grooming</option>
              <option value="Pest Control">Pest Control & Home Protection</option>
              <option value="Event Organization">Event Organization & Hospitality Services</option>
            </select>
          </div>
          
          <div class="form-group">
            <label>Location (Google Maps Pin/Address)</label>
            <input type="text" class="form-control" name="location" placeholder="e.g. Juja City Mall" required>
          </div>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;" class="form-grid">
            <div class="form-group">
              <label>Preferred Date</label>
              <input type="date" class="form-control" name="date" required>
            </div>
            <div class="form-group">
              <label>Preferred Time</label>
              <input type="time" class="form-control" name="time" required>
            </div>
          </div>
          
          <div class="form-group">
            <label>Additional Notes</label>
            <textarea class="form-control" name="notes" rows="3" placeholder="Any specific requirements?"></textarea>
          </div>
          
          <button type="submit" id="submitBtn" class="btn-primary">Confirm Booking</button>
          <div id="formMessage" style="margin-top: 15px; text-align: center; font-weight: 500;"></div>
        </form>
      </div>
    </div>
  </div>

  <script>
    // 5 Consolidated Master Service Categories with High-Quality Real Images
    const servicesData = [
      { 
        title: "Comprehensive Cleaning", 
        img: "https://images.unsplash.com/photo-1527515637462-cff94eecc1ac?w=800&q=80", 
        shortDesc: "Spotless, safe, and hygienic environments.",
        included: ["Residential Deep Cleaning & Sanitization", "Office Cleaning & Workplace Support", "Institutional Facility Cleaning", "Move-in / Move-out Cleaning"],
        target: "Family homes, apartments, corporate offices, schools, and hospitals.",
        benefits: "Reduces stress, prevents diseases, and improves living/working quality."
      },
      { 
        title: "Space Organization & Relocation", 
        img: "https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&q=80", 
        shortDesc: "Maximize space and safely move your assets.",
        included: ["Home Organization & Rearranging", "Indoor Relocation & Furniture Movement", "Wardrobe and Kitchen Decluttering", "Airbnb Room Setup"],
        target: "Homeowners, renters, Airbnb hosts, and corporate offices.",
        benefits: "Enhances comfort and functionality without heavy lifting or risk of damage."
      },
      { 
        title: "Home Improvement & Repairs", 
        img: "https://images.unsplash.com/photo-1581141849291-1125c7b692b5?w=800&q=80", 
        shortDesc: "Transform homes into stylish, functional spaces.",
        included: ["Interior Design Consultation", "TV Mounting & Curtain Installation", "Furniture Assembly", "Minor Plumbing & Electrical Repairs"],
        target: "New homeowners, renters, and property managers.",
        benefits: "Creates a visually appealing living space with reliable technical support."
      },
      { 
        title: "Specialized Care & Protection", 
        img: "https://images.unsplash.com/photo-1542838132-92c53300491e?w=800&q=80", 
        shortDesc: "Professional support for your family, pets, and property.",
        included: ["Child Supervision & Homework Support", "Pet Care, Washing & Walking", "Pest Control & Home Fumigation"],
        target: "Working parents, busy families, and property owners.",
        benefits: "Provides peace of mind, healthy pets, and safe, pest-free environments."
      },
      { 
        title: "Event & Hospitality Services", 
        img: "https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=800&q=80", 
        shortDesc: "Seamless event management for home and corporate.",
        included: ["Event Setup and Decoration", "Private Chefs & Catering", "Waiters, Cleaners & Support Staff", "Venue Logistics Supervision"],
        target: "Event planners, corporations, families, and institutions.",
        benefits: "Clients enjoy stress-free, professional, and top-tier event execution."
      }
    ];

    const track = document.getElementById('carouselTrack');
    
    // Render the 5 Landscape Cards
    function renderServices() {
      track.innerHTML = '';
      servicesData.forEach((srv) => {
        let listHTML = srv.included.map(item => `<li>${item}</li>`).join('');
        
        const card = document.createElement('div');
        card.className = 'service-card';
        card.innerHTML = `
          <div class="card-img" style="background-image: url('${srv.img}');"></div>
          <div class="card-content-wrapper">
            <div class="card-content">
              <h3>${srv.title}</h3>
              <p class="desc">${srv.shortDesc}</p>
              
              <div class="card-section-title"><i class="fas fa-list-check"></i> Included Services</div>
              <ul class="card-list">${listHTML}</ul>
              
              <div class="card-section-title"><i class="fas fa-users"></i> Target Clients</div>
              <p class="card-list">${srv.target}</p>
              
              <div class="card-section-title"><i class="fas fa-check-circle"></i> Benefits</div>
              <p class="card-list">${srv.benefits}</p>
            </div>
            <div class="card-footer">
              <button class="btn-primary" onclick="openBookingModal()">Book Services From This Category</button>
            </div>
          </div>
        `;
        track.appendChild(card);
      });
    }
    renderServices();

    // Auto-Scroll Logic (2 Seconds) & Pause on Touch/Hover
    let scrollPos = 0;
    let slideInterval;

    function startSlider() {
      slideInterval = setInterval(() => {
        // 940 is the card width (900px) + gap (40px)
        const slideWidth = window.innerWidth <= 950 ? window.innerWidth * 0.9 + 40 : 940;
        
        if(track.scrollWidth - track.clientWidth <= scrollPos) { 
          scrollPos = 0; 
        } else { 
          scrollPos += slideWidth; 
        } 
        track.style.transform = `translateX(-${scrollPos}px)`;
      }, 2000); // Sliding every 2 seconds
    }

    function stopSlider() { clearInterval(slideInterval); }

    // Pause the slider on hover/touch so users can read and click
    track.addEventListener('mouseenter', stopSlider);
    track.addEventListener('mouseleave', startSlider);
    track.addEventListener('touchstart', stopSlider);
    track.addEventListener('touchend', startSlider);

    // Initialize Slider
    startSlider();

    // Booking Modal Logic
    function openBookingModal() {
      document.getElementById('bookingModal').classList.add('active');
    }
    
    function closeBookingModal() { document.getElementById('bookingModal').classList.remove('active'); }

    // Form Submission
    function submitBooking(event) {
      event.preventDefault();
      const btn = document.getElementById('submitBtn');
      const msg = document.getElementById('formMessage');
      const form = document.getElementById('bookingForm');
      
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
      btn.disabled = true;
      
      const formData = new FormData(form);
      const obj = {}; formData.forEach((v, k) => obj[k] = v);
      
      google.script.run
        .withSuccessHandler(res => {
          msg.style.color = res.success ? 'var(--primary-green)' : 'red';
          msg.innerText = res.message;
          if(res.success) { form.reset(); setTimeout(closeBookingModal, 4000); }
          btn.innerHTML = 'Confirm Booking'; btn.disabled = false;
        })
        .withFailureHandler(err => {
          msg.style.color = 'red'; msg.innerText = "Connection error. Please ensure you are connected to the internet.";
          btn.innerHTML = 'Confirm Booking'; btn.disabled = false;
        })
        .processBooking(obj);
    }
  </script>
</body>
</html>
